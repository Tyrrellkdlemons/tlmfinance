# TLM Finance - Environment Variables Example
#
# IMPORTANT: These are ONLY needed for Netlify serverless functions.
# Local development requires ZERO configuration!
#
# To use:
# 1. Copy this file (don't rename it - it's just for reference)
# 2. In Netlify Dashboard → Site Settings → Environment Variables
# 3. Add only the variables you need from below
#
# See docs/ENVIRONMENT_VARIABLES.md for detailed descriptions

# ============================================
# Required for AI Chatbot
# ============================================
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Customize chatbot metadata
# OPENROUTER_REFERRER=https://tlmfinance.netlify.app
# OPENROUTER_TITLE=TLM Finance


# ============================================
# Optional - Email Notifications
# ============================================
# Get API key at: https://resend.com
# RESEND_API_KEY=your_resend_api_key_here


# ============================================
# Optional - SMS Notifications (Twilio)
# ============================================
# Get credentials at: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=+1234567890


# ============================================
# Optional - Neon Database Sync
# ============================================
# Get database URL at: https://neon.tech
# NEON_DATABASE_URL=postgresql://user:password@host/database
# SYNC_ENABLED=true


# ============================================
# Optional - Text-to-Speech (ElevenLabs)
# ============================================
# Get API key at: https://elevenlabs.io
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=default_voice_id
# ELEVENLABS_MODEL_ID=default_model_id


# ============================================
# Auto-Set by Netlify (do not set manually)
# ============================================
# NETLIFY_API_TOKEN=auto_set_by_netlify
# NETLIFY_SITE_ID=auto_set_by_netlify
